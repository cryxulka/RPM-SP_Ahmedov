<Window x:Class="TsvLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузка TSV" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnLoad" Content="Загрузить и показать данные" 
                Click="btnLoad_Click" Margin="10" Padding="5"/>
        <DataGrid x:Name="dataGrid" Grid.Row="1" Margin="10" 
                  AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Window>